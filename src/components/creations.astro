---
const creations = [
  { name: 'Deep\nEarth', desktop: 'images/desktop/image-deep-earth.jpg', mobile: 'images/mobile/image-deep-earth.jpg' },
  { name: 'Night\nArcade', desktop: 'images/desktop/image-night-arcade.jpg', mobile: 'images/mobile/image-night-arcade.jpg' },
  { name: 'Soccer\nTeam VR', desktop: 'images/desktop/image-soccer-team.jpg', mobile: 'images/mobile/image-soccer-team.jpg' },
  { name: 'The\nGrid', desktop: 'images/desktop/image-grid.jpg', mobile: 'images/mobile/image-grid.jpg' },
  { name: 'From Up\nAbove VR', desktop: 'images/desktop/image-from-above.jpg', mobile: 'images/mobile/image-from-above.jpg' },
  { name: 'Pocket\nBorealis', desktop: 'images/desktop/image-pocket-borealis.jpg', mobile: 'images/mobile/image-pocket-borealis.jpg' },
  { name: 'The\nCuriosity', desktop: 'images/desktop/image-curiosity.jpg', mobile: 'images/mobile/image-curiosity.jpg' },
  { name: 'Make It\nFisheye', desktop: 'images/desktop/image-fisheye.jpg', mobile: 'images/mobile/image-fisheye.jpg' },
]; 
---
<section class="px-6 md:px-10 lg:px-40 pb-24">
  <div class="flex items-center justify-between mb-10">
    <h2 class="font-['Josefin_Sans'] uppercase font-light text-3xl md:text-4xl tracking-widest">Our Creations</h2>
    <a href="#" class="hidden md:block border border-black px-8 py-2 text-sm tracking-widest uppercase font-[Alata] hover:bg-black hover:text-white transition-colors duration-300">
      See All
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-6">
    {creations.map(item => (
      <div class="relative group cursor-pointer overflow-hidden">
        <picture>
          <source media="(min-width: 768px)" srcset={item.desktop} />
          <img src={item.mobile} alt={item.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
        </picture>
        <div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/10 to-transparent group-hover:from-white/60 transition-all duration-300"></div>
        <p class="absolute bottom-4 left-5 text-white font-['Josefin_Sans'] uppercase font-light text-xl leading-tight whitespace-pre-line group-hover:text-black transition-colors duration-300">
          {item.name}
        </p>
      </div>
    ))}
  </div>

  <div class="flex justify-center mt-8 md:hidden">
    <a href="#" class="border border-black px-16 py-2 text-sm tracking-widest uppercase font-[Alata] hover:bg-black hover:text-white transition-colors duration-300">
      See All
    </a>
  </div>
</section>